# =============================================================================
# greggorpages - Environment Configuration
# =============================================================================
# Copy this file to .env.local (for local dev) or set in your Docker container.
# All variables are optional EXCEPT API_KEY, which is required for API access.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Master API Key
# -----------------------------------------------------------------------------
# Without this, ALL /api/* endpoints return 503 "API is disabled".
# Pass this key in every API request via header "X-API-Key" or query "api_key".
# -----------------------------------------------------------------------------
API_KEY=your-very-secret-master-api-key

# -----------------------------------------------------------------------------
# App Status Gate (Middleware)
# -----------------------------------------------------------------------------
# URL that returns the current app status: public | maintenance | devmode | testing
# The middleware fetches this on every request to decide whether to block,
# show maintenance, or require login.
# -----------------------------------------------------------------------------
APP_STATUS_URL=https://datacentermods.com/api/status

# -----------------------------------------------------------------------------
# DevMode / Testing Access Passwords
# -----------------------------------------------------------------------------
# Used when APP_STATUS_URL returns "devmode" or "testing".
# Visitors must enter this password to unlock the site.
# TESTING_PASSWORD falls back to DEVMODE_PASSWORD if unset.
# -----------------------------------------------------------------------------
DEVMODE_PASSWORD=your-devmode-password
TESTING_PASSWORD=your-testing-password

# -----------------------------------------------------------------------------
# Deploy Middleware (/api/git-push)
# -----------------------------------------------------------------------------
# Additional secret for the git-push webhook endpoint.
# Checked AFTER the master API_KEY.
# -----------------------------------------------------------------------------
GIT_PUSH_SECRET=your-webhook-secret

# Optional: Forward deploy events to another service (Discord, Slack, etc.)
WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# -----------------------------------------------------------------------------
# Self-Update (/api/self-update)
# -----------------------------------------------------------------------------
# Base path for allowed deploy directories. All X-Deploy-Path headers must
# resolve inside this directory. Prevents path traversal attacks.
# Example: /opt/docker-infra
# -----------------------------------------------------------------------------
DEPLOY_BASE_PATH=/opt/docker-infra

# Optional: Comma-separated whitelist of allowed deploy paths.
# If set, X-Deploy-Path must match one of these prefixes.
# Example: /opt/docker-infra/proxy-and-security/errorpages,/opt/docker-infra/modstore
# ALLOWED_DEPLOY_PATHS=

# -----------------------------------------------------------------------------
# Uptime Kuma Integration (also configured in design.json)
# -----------------------------------------------------------------------------
# These are OPTIONAL overrides. Usually configured in design.json instead.
# Only needed if you want ENV-based overrides for Kuma connection.
# -----------------------------------------------------------------------------
# KUMA_BASE_URL=https://status.example.com
# KUMA_API_KEY=your-kuma-api-key
